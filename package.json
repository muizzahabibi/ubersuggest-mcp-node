{
  "name": "ubersuggest-mcp-node",
  "version": "0.1.0",
  "bin": "./install-remote.js",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "node --no-warnings --experimental-sqlite --env-file=.env dist/server.js",
    "dev:watch": "tsc -p tsconfig.json --watch",
    "setup": "node install.js",
    "start": "node --no-warnings --experimental-sqlite --env-file=.env dist/server.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.28.0",
    "playwright": "^1.55.0",
    "zod": "^4.1.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260403.0",
    "@types/node": "^24.0.0",
    "typescript": "^5.9.0"
  }
}
